# ── Database ────────────────────────────────────────────────────────────────
# For local: mongodb://localhost:27017/safehers
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/safehers
MONGODB_URI=mongodb://localhost:27017/safehers

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@safehers.africa
ADMIN_PASSWORD=change-me-in-production

# ── Resend (https://resend.com) ───────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Email address that receives new contact form submissions
NOTIFICATION_EMAIL=hello@safehers.africa
