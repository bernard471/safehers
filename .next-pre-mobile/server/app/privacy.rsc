,"2",{"dangerouslySetInnerHTML":{"__html":"EEA/UK residents additionally have GDPR rights to data portability and restriction of processing."}}],["$","p","3",{"dangerouslySetInnerHTML":{"__html":"To exercise any right, contact privacy@safehers.africa. We will respond within 30 days. You may lodge a complaint with the Data Protection Commission of Ghana or your local supervisory authority."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","data-transfers",{"id":"data-transfers","children":[["$","div",null,{"className":"flex items-start gap-4 mb-6","children":[["$","span",null,{"className":"num-tag text-2xl text-ink/30 mt-1 shrink-0","children":"09"}],["$","h2",null,{"className":"display text-3xl font-light","children":"International Data Transfers"}]]}],["$","div",null,{"className":"body-prose text-ink/80 space-y-4 pl-10","children":[["$","p","0",{"dangerouslySetInnerHTML":{"__html":"SafeHers operates from Ghana and the United States. Transfers outside the EEA are protected by Standard Contractual Clauses approved by the European Commission, adequacy decisions, or other appropriate safeguards permitted under the GDPR."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","children",{"id":"children","children":[["$","div",null,{"className":"flex items-start gap-4 mb-6","children":[["$","span",null,{"className":"num-tag text-2xl text-ink/30 mt-1 shrink-0","children":"10"}],["$","h2",null,{"className":"display text-3xl font-light","children":"Children's Privacy"}]]}],["$","div",null,{"className":"body-prose text-ink/80 space-y-4 pl-10","children":[["$","p","0",{"dangerouslySetInnerHTML":{"__html":"Our website is not directed at children under 13 (or 16 in the EEA). We do not knowingly collect data from children. If you believe a child has provided us data without parental consent, contact privacy@safehers.africa and we will delete it promptly."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","changes",{"i