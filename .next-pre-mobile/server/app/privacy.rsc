bmit a message we collect your full name, email address, country, organisation name (optional), area of interest, and message content."}}],["$","p","3",{"dangerouslySetInnerHTML":{"__html":"Newsletter Subscription: When you subscribe we collect your email address and the timestamp of subscription."}}],["$","p","4",{"dangerouslySetInnerHTML":{"__html":"Resource Downloads: We collect your email address, the resource requested, download timestamp, and country."}}],["$","p","5",{"dangerouslySetInnerHTML":{"__html":"<strong>Information collected automatically</strong>"}}],["$","p","6",{"dangerouslySetInnerHTML":{"__html":"Server Logs: Our hosting infrastructure may log your IP address, browser type, OS, referral URL, and pages visited. Logs are retained for a maximum of 30 days."}}],["$","p","7",{"dangerouslySetInnerHTML":{"__html":"Cookies: We use strictly necessary session cookies and optional analytics cookies. See the Cookies section below."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","how-we-use",{"id":"how-we-use","children":[["$","div",null,{"className":"flex items-start gap-4 mb-6","children":[["$","span",null,{"className":"num-tag text-2xl text-ink/30 mt-1 shrink-0","children":"03"}],["$","h2",null,{"className":"display text-3xl font-light","children":"How We Use Your Data"}]]}],["$","div",null,{"className":"body-prose text-ink/80 space-y-4 pl-10","children":[["$","p","0",{"dangerouslySetInnerHTML":{"__html":"We use your personal data only for the purposes for which it was collected:"}}],["$","p","1",{"dangerouslySetInnerHTML":{"__html":"To respond to contact form enquiries and service requests.<br />To send our newsletter to subscribers who have opted in.<br />To process and fulfil resource download requests.<br />To improve our website and content through aggregated analytics.<br />To detect and prevent fraud, spam, and abusive activity.<br />To comply with applicable law."}}],["$","p","2",{"dangerouslySetInnerHTML":{"__html":"We do not sell, rent, or trade your personal data to third parties for marketing purposes."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","legal-basis",{"id":"legal-basis","children":[["$","div",null,{"className":"flex items-start gap-4 mb-6","children":[["$","span",null,{"className":"num-tag text-2xl text-ink/30 mt-1 shrink-0","children":"04"}],["$","h2",null,{"className":"display text-3xl font-light","children":"Legal Basis for Processing"}]]}],["$","div",null,{"className":"body-prose text-ink/80 space-y-4 pl-10","children":[["$","p","0",{"dangerouslySetInnerHTML":{"__html":"Under the Ghana Data Protection Act 2012 and the GDPR we must have a lawful basis for processing your data."}}],["$","p","1",{"dangerouslySetInnerHTML":{"__html":"<strong>Consent</strong> — Newsletter subscriptions and optional analytics cookies are processed on the basis of your explicit consent. You may withdraw consent at any time."}}],["$","p","2",{"dangerouslySetInnerHTML":{"__html":"<strong>Legitimate Interests</strong> — Contact form submissions and server logs are processed on the basis of our legitimate interest in responding to enquiries and maintaining site security."}}],["$","p","3",{"dangerouslySetInnerHTML":{"__html":"<strong>Legal Obligation</strong> — We may process data where required by applicable law or court order."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","mongodb-storage",{"id":"mongodb-storage","children":[["$","div",null,{"className":"flex items-start gap-4 mb-6","children":[["$","span",null,{"className":"num-tag text-2xl text-ink/30 mt-1 shrink-0","children":"05"}],["$","h2",null,{"className":"display text-3xl font-light","children":"Data Storage and Security"}]]}],["$","div",null,{"className":"body-prose text-ink/80 space-y-4 pl-10","children":[["$","p","0",{"dangerouslySetInnerHTML":{"__html":"Your personal data is stored in a MongoDB Atlas database. MongoDB Atlas is certified to ISO 27001 and SOC 2 Type II standards and provides encryption at rest (AES-256) and in transit (TLS 1.2+)."}}],["$","p","1",{"dangerouslySetInnerHTML":{"__html":"Database access is restricted to our application servers and authorised personnel only. We store only the fields necessary for each use case."}}],["$","p","2",{"dangerouslySetInnerHTML":{"__html":"<strong>Retention periods:</strong> Contact form data — 24 months. Newsletter subscription data — until unsubscribe. Resource download records — 12 months."}}],["$","p","3",{"dangerouslySetInnerHTML":{"__html":"Despite our best efforts, no method of transmission over the internet is 100% secure. If you become aware of a security incident please contact privacy@safehers.africa immediately."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","cookies",{"id":"cookies","children":[["$","div",null,{"className":"flex items-start gap-4 mb-6","children":[["$","span",null,{"className":"num-tag text-2xl text-ink/30 mt-1 shrink-0","children":"06"}],["$","h2",null,{"className":"display text-3xl font-light","children":"Cookies"}]]}],["$","div",null,{"className":"body-prose text-ink/80 space-y-4 pl-10","children":[["$","p","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Strictly Necessary Cookies</strong> (always active) — Required for the site to function. Includes session management and security tokens. These cannot be switched off."}}],["$","p","1",{"dangerouslySetInnerHTML":{"__html":"<strong>Analytics Cookies</strong> (optional, require consent) — If accepted, we use Vercel Analytics to understand which pages are most visited. Data is aggregated and anonymised — no personal profiles are built. You can change your preference at any time via the cookie banner."}}],["$","p","2",{"dangerouslySetInnerHTML":{"__html":"We do not use advertising, social media tracking, or cross-site tracking cookies."}}]]}],["$","div",null,{"className":"divider-rule mt-16"}]]}],["$","div","third-parties",{"id":"third-parties","children":[["$","div",null,{"clas