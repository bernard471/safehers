0:["mUZnaPBou1EbR9tyF78t2",[[["",{"children":["financial-literacy",{"children":["wealth-building",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["financial-literacy",{"children":["wealth-building",{"children":["__PAGE__",{},[["$L1",[["$","section",null,{"className":"pt-40 pb-20 lg:pt-48","children":["$","div",null,{"className":"max-w-[1400px] mx-auto px-6 lg:px-12","children":[["$","p",null,{"className":"eyebrow mb-4 flex items-center gap-3","children":[["$","$L2",null,{"href":"/financial-literacy","className":"opacity-60 hover:opacity-100 transition-opacity","children":"Financial Safety & Wealth"}],["$","span",null,{"className":"opacity-30","children":"/"}],"Module 06"]}],["$","h1",null,{"className":"display text-[clamp(2.5rem,7vw,7rem)] font-light max-w-[900px]","children":["Wealth",["$","br",null,{}],["$","span",null,{"className":"display-italic text-burgundy","children":"Building"}]]}],["$","p",null,{"className":"body-prose mt-6 max-w-2xl text-ink/70","children":"Pensions, property, estate planning, and building generational wealth in the African context."}],["$","div",null,{"className":"border border-ink/20 bg-bone p-6 my-8","children":[["$","p",null,{"className":"font-mono text-xs tracking-widest uppercase opacity-50 mb-2","children":"Educational disclaimer"}],["$","p",null,{"className":"text-sm text-ink/70 leading-relaxed","children":"The content on this page is provided for educational purposes only. It does not constitute personalised financial advice and should not be relied upon as such. SafeHer Foundation is not a licensed financial advisor. Before making any financial decision, please consult a qualified financial professional licensed in your jurisdiction."}]]}]]}]}],["$","section",null,{"className":"pb-32","children":["$","div",null,{"className":"max-w-[1400px] mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"max-w-3xl space-y-12","children":[["$","div","0",{"className":"border-t border-ink/15 pt-8","children":[["$","h2",null,{"className":"display text-2xl lg:text-3xl mb-4","children":"Defining wealth vs. income"}],["$","p",null,{"className":"body-prose text-ink/75","children":"Income is what you earn. Wealth is what you keep, grow, and pass on. Many high-income women in Africa are not building wealth because their income is immediately absorbed by family obligations, lifestyle costs, and informal support networks — none of which build personal net worth. Understanding this distinction is the foundation for intentional wealth building."}]]}],["$","div","1",{"className":"border-t border-ink/15 pt-8","children":[["$","h2",null,{"className":"display text-2xl lg:text-3xl mb-4","children":"SSNIT and formal pension systems"}],["$","p",null,{"className":"body-prose text-ink/75","children":"The Social Security and National Insurance Trust (SSNIT) is Ghana's mandatory pension scheme, requiring contributions from formal sector workers and their employers. Many self-employed and informal sector women are not enrolled. We explain the three-tier pension structure in Ghana, how to enroll as a self-employed individual, and why pension contributions are a form of forced wealth building even when they feel like an inconvenience."}]]}],["$","div","2",{"className":"border-t border-ink/15 pt-8","children":[["$","h2",null,{"className":"display text-2xl lg:text-3xl mb-4","children":"Land as a wealth vehicle: verification and documentation"}],["$","p",null,{"className":"body-prose text-ink/75","children":"Land remains the primary inter-generational wealth transfer mechanism in most of Africa. However, land disputes are common. We explain the importance of conducting land searches at the Lands Commission before any purchase, what a site plan is and why you need one, the difference between allocation papers, indenture, and land title certificate, and why family land without documentation is not reliable wealth."}]]}],["$","div","3",{"className":"border-t border-ink/15 pt-8","children":[["$","h2",null,{"className":"display text-2xl lg:text-3xl mb-4","children":"Generational wealth: estate planning basics"}],["$","p",null,{"className":"body-prose text-ink/75","children":"Generational wealth requires intentional estate planning. We explain wills (how to make a legally valid will in Ghana), trusts (useful for protecting assets for children), beneficiary designations on bank accounts and insurance policies, and the role of a licensed attorney in ensuring your estate plan actually works. The goal is not just to accumulate — but to ensure what you build can be transferred to your children or chosen beneficiaries."}]]}],["$","div","4",{"className":"border-t border-ink/15 pt-8","children":[["$","h2",null,{"className":"display text-2xl lg:text-3xl mb-4","children":"The gender wealth gap and systemic barriers"}],["$","p",null,{"className":"body-prose text-ink/75","children":"Women in sub-Saharan Africa face documented structural barriers to wealth building: land tenure laws that favour men, informal sector concentration with no pension access, caregiving obligations that reduce earning years, and credit markets that under-serve women-led businesses. Understanding these is not about helplessness — it is about naming what you are working against, advocating for change, and finding the workarounds that exist within the current system."}]]}],["$","div","5",{"className":"border-t border-ink/15 pt-8","children":[["$","h2",null,{"className":"display text-2xl lg:text-3xl mb-4","children":"Building a personal net worth statement"}],["$","p",null,{"className":"body-prose text-ink/75","children":"A net worth statement lists all assets (things you own or are owed) minus all liabilities (debts). Tracking net worth annually is a better measure of financial progress than income alone. We walk through how to build a simple net worth statement using a notebook or spreadsheet, what to include (mobile money balances, savings accounts, property value, business equity, pension balance) and what not to forget (mobile loans, credit card balances, family debts)."}]]}]]}],["$","div",null,{"className":"mt-20 p-8 bg-ink text-cream","children":[["$","p",null,{"className":"eyebrow mb-3 opacity-60","children":"You have completed the curriculum"}],["$","h2",null,{"className":"display text-3xl mb-6","children":"All six modules complete ✦"}],["$","div",null,{"className":"flex flex-wrap gap-4","children":[["$","$L2",null,{"href":"/calculators","className":"bg-cream text-ink px-8 py-4 eyebrow hover:bg-rose transition-colors","children":"Try the calculators"}],["$","$L2",null,{"href":"/coaches","className":"border border-cream/40 px-8 py-4 eyebrow hover:border-cream transition-colors","children":"Work with a coach"}],["$","$L2",null,{"href":"/financial-literacy","className":"border border-cream/40 px-8 py-4 eyebrow hover:border-cream transition-colors","children":"Back to overview"}]]}]]}]]}]}]],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","financial-literacy","children","wealth-building","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","financial-literacy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/cdc9671e5cdf3b87.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","children":["$","body",null,{"className":"grain","children":["$","$L5",null,{"children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$6